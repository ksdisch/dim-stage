# artifact policy decided at M0 — until then, never tracked.
*.pt
*.safetensors
lenses/

# Run logs (results that matter get written into docs/, not committed as logs)
*.log

# Fetched reference material — the paper (Anthropic's content, never commit)
# and the reference jlens clone (cross-check oracle, consumed as a dev-dep)
refs/

# OS
.DS_Store

# Prefetched D3 prompt dump (deterministic, rebuildable — see fitter.py --prompts-file)
wikitext-n100-prompts.json
